#!/usr/bin/env bash
#
# wharf — run Windows 11 / 10 ARM on Apple silicon, the "dockur way" but native.
#
# Runs QEMU directly on macOS with the HVF accelerator (the engine UTM uses for
# Windows) wrapped in dockur-style automation: auto ISO download + virtio driver
# injection + unattended install + viewer. Manages multiple named VMs.
#
# VM commands (named VMs live under ~/.wharf/<name>/):
#   wharf new <name>     create a VM and install Windows into it (zero-touch)
#   wharf ls             list all VMs (status, edition, ports, disk)
#   wharf rm <name>      stop and delete a VM
#   wharf run [name]     boot an installed VM from its disk
#   wharf stop [name]    gracefully power off / kill a running VM
#   wharf status [name]  show whether a VM is running + how to view it
#   wharf view [name]    open a VNC viewer onto a running VM
#   wharf install        create/install the default VM (legacy single-VM, in ./storage)
#   wharf doctor         check host dependencies
#
# With no [name], run/stop/status/view act on the default ./storage VM.
# Settings: VERSION/RAM_SIZE/CPU_CORES/DISK_SIZE/USERNAME/PASSWORD via env or
# wharf.conf; for `new`, they're captured into the VM's ~/.wharf/<name>/vm.conf.
#   e.g.   VERSION=11 RAM_SIZE=8G wharf new dev

set -Eeuo pipefail

WHARF_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export WHARF_HOME

# shellcheck source=lib/config.sh
source "$WHARF_HOME/lib/config.sh"
for m in deps vm firmware disk network display qemu iso prepare; do
  # shellcheck disable=SC1090
  source "$WHARF_HOME/lib/$m.sh"
done

usage() { sed -n '3,28p' "$WHARF_HOME/wharf" | sed 's/^# \{0,1\}//'; }

cmd_install() {
  deps_require qemu-system-aarch64 qemu-img
  config_summary
  : > "$STORAGE/.installing"   # state marker so 'wharf ls/status' shows "installing"
  firmware_setup           # edk2 code (ro) + writable vars copy
  iso_acquire              # download or locate the Windows ARM ISO  -> $ISO
  prepare_media            # inject virtio drivers + autounattend.xml -> $ISO_PREPARED
  disk_create              # qemu-img create growable raw -> $DISK
  log "Starting installer. This is unattended — it will reboot itself to the desktop."
  qemu_boot install        # boot Setup (disk-first, CD fallback)
  rm -f "$STORAGE/.installing"   # qemu is up now; clear the marker
}

cmd_new() {
  local name="${1:-}"
  [ -n "$name" ] || die "usage: wharf new <name>   (e.g. VERSION=11 wharf new win11)"
  mkdir -p "$WHARF_VMS"
  [ -d "$WHARF_VMS/$name" ] && die "VM '$name' already exists (wharf rm $name first)"
  deps_require qemu-system-aarch64 qemu-img
  STORAGE="$WHARF_VMS/$name"; NAME="$name"; mkdir -p "$STORAGE"
  vm_alloc_ports
  vm_save_conf
  config_paths
  log "Created VM '$name' — console VNC 127.0.0.1:$((5900+VNC_DISPLAY)), RDP 127.0.0.1:$RDP_PORT"
  cmd_install
}

cmd_rm() {
  local name="${1:-}"
  [ -n "$name" ] || die "usage: wharf rm <name>"
  vm_resolve "$name"
  vm_running "$STORAGE" && { log "Stopping '$name'..."; qemu_stop || true; }
  chmod -R u+w "$STORAGE" 2>/dev/null || true
  rm -rf "$STORAGE"
  log "Removed VM '$name'"
}

cmd_run() {
  [ -n "${1:-}" ] && vm_resolve "$1"
  deps_require qemu-system-aarch64
  [ -f "$DISK" ] || die "No disk at $DISK — install it first (wharf new <name>)."
  firmware_setup
  qemu_boot run            # no ISO, boot from disk
}

cmd_stop()   { [ -n "${1:-}" ] && vm_resolve "$1"; qemu_stop; }
cmd_status() { [ -n "${1:-}" ] && vm_resolve "$1"; qemu_status; }
cmd_view()   { [ -n "${1:-}" ] && vm_resolve "$1"; display_open; }
cmd_doctor() { deps_check_all; }

main() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    new)               cmd_new "$@" ;;
    ls|list)           vm_ls ;;
    rm|destroy|delete) cmd_rm "$@" ;;
    install)           cmd_install "$@" ;;
    run)               cmd_run "$@" ;;
    stop)              cmd_stop "$@" ;;
    status)            cmd_status "$@" ;;
    view)              cmd_view "$@" ;;
    doctor)            cmd_doctor "$@" ;;
    ""|-h|--help|help) usage ;;
    *) die "Unknown subcommand: $sub (try: wharf help)" ;;
  esac
}

main "$@"
